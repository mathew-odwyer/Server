# =========================================================
# Reverse Proxy Configuration
# =========================================================

# The reverse proxy domain name (or localhost if running locally).
APP_DOMAIN=localhost

# Email address used for ACME registration (e.g. Let's Encrypt)
# Caddy uses this to issue and manage TLS certificates
# Should be a valid email you control
TLS_EMAIL=internal

# Hostname of the upstream application the proxy forwards to
# In Docker, this is typically the service name (e.g. "server")
# If running outside Docker, this could be "localhost" or an IP
APP_HOST=gateway

# Port of the upstream application
# Must match the port your backend service is listening on
APP_PORT=8080

# =========================================================
# Application Environment
# =========================================================

# The default environment for the entire application
APPLICATION_ENVIRONMENT=Development

# ASP.NET Core environment
# Set to "Production" in production deployments
ASPNETCORE_ENVIRONMENT=${APPLICATION_ENVIRONMENT}

# =========================================================
# Service Connections
# =========================================================

# Redis connection string
# Uses Docker service name "redis" by default
# Change to localhost or external host if running outside Docker
REDIS_URL=redis://redis:6379

# NATS WebSocket endpoint
# Uses Docker service name "nats" by default
NATS_URL=ws://nats:9222

# Internal API endpoint
# Uses Docker service name "web" by default
API_URL=http://api:8080

# =========================================================
# Licensing / Database
# =========================================================

# Required to accept SQL Server container license terms
ACCEPT_EULA=Y

# SQL Server system administrator password
# MUST meet complexity requirements:
# - At least 8 characters
# - Uppercase, lowercase, number, and symbol
# NEVER commit a real password to version control
SA_PASSWORD=<<CHANGE HERE>>

# =========================================================
# Debug Tools
# =========================================================

# Enable scalar UI from within the dockerized environment
# (example: https://localhost:433/scalar/v0.3.0
SCALAR_ENABLED=True
